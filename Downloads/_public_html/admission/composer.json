{
  "name": "vvit/admission-system",
  "description": "VVIT College Admission System with PDF, QR Code, Checklist",
  "type": "project",
  "license": "MIT",

  "require": {
    "php": ">=8.1",
    "tecnickcom/tcpdf": "^6.7",
    "phpmailer/phpmailer": "^6.9"
  },

  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },

  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },

  "minimum-stability": "stable",
  "prefer-stable": true
}
